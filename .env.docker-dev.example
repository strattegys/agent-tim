# Optional: copy to COMMAND-CENTRAL/.env (same folder as docker-compose.dev.yml).
# Docker Compose reads .env for ${VAR} substitution in compose files only (not Next.js).

# --- Default LOCALDEV: bundled crm-db in docker-compose.dev.yml ---
# Leave CC_DOCKER_* unset; web uses CRM_DB_HOST=crm-db CRM_DB_PORT=5432.

# --- Recommended: remote droplet CRM from dev container (no bridge — survives PC restart) ---
# When Docker Desktop can reach your CC Tailscale IP (test: docker run --rm alpine sh -c "apk add --no-cache postgresql16-client && pg_isready -h YOUR_CC_100.x -p 5432"):
CC_DOCKER_CRM_DB_HOST=100.74.54.12
CC_DOCKER_CRM_DB_PORT=5432
# After first setup: recreate web so env applies — .\scripts\dev-docker-up.ps1 (prepends .env automatically), or:
#   docker compose --env-file .env --env-file web/.env.local -f docker-compose.dev.yml up -d --no-deps --force-recreate web
# (web/.env.local alone does NOT load this file for ${CC_DOCKER_*} interpolation — always pass .env first when present.)

# --- Fallback: host bridge/tunnel on 5433 (dies on reboot unless you restart it) ---
# Use .\scripts\dev-docker-up.ps1 -UseRemoteCrm, or set:
# CC_DOCKER_CRM_DB_HOST=host.docker.internal
# CC_DOCKER_CRM_DB_PORT=5433
