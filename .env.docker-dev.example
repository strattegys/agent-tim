# Optional: copy to COMMAND-CENTRAL/.env (same folder as docker-compose.dev.yml).
# Docker Compose reads .env for ${VAR} substitution in compose files only (not Next.js).
#
# LOCALDEV **defaults** (no .env required): web container uses droplet CRM 100.74.54.12:5432 over Tailscale
# (same as LOCALPROD Docker / production data). web/.env.local must set CRM_DB_PASSWORD to match the droplet.
#
# Optional: use the **same** keys as LOCALPROD instead of CC_DOCKER_* (docker-compose.dev.yml falls back to these):
# CC_LOCALPROD_CRM_HOST=100.74.54.12
# CC_LOCALPROD_CRM_PORT=5432
#
# Dev-only override (wins over CC_LOCALPROD_*):
CC_DOCKER_CRM_DB_HOST=100.74.54.12
CC_DOCKER_CRM_DB_PORT=5432
#
# --- Bundled empty local Postgres (offline / experiments): ---
# docker compose --env-file web/.env.local -f docker-compose.dev.yml --profile bundled-crm-postgres up -d
# Then set CC_DOCKER_CRM_DB_HOST=crm-db  CC_DOCKER_CRM_DB_PORT=5432 here and recreate web.
#
# Recreate web after changing .env:
#   .\scripts\dev-docker-up.ps1
#   or: docker compose --env-file .env --env-file web/.env.local -f docker-compose.dev.yml up -d --no-deps --force-recreate web

# --- Fallback: host bridge/tunnel on 5433 (dies on reboot unless you restart it) ---
# .\scripts\dev-docker-up.ps1 -UseRemoteCrm — or set:
# CC_DOCKER_CRM_DB_HOST=host.docker.internal
# CC_DOCKER_CRM_DB_PORT=5433
