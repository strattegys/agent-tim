# Optional: copy lines you need into COMMAND-CENTRAL/.env (same folder as docker-compose.dev.yml).
# Docker Compose reads .env for ${VAR} substitution in compose files only (not Next.js).

# --- Default LOCALDEV: bundled crm-db in docker-compose.dev.yml ---
# Leave CC_DOCKER_* unset; web uses CRM_DB_HOST=crm-db CRM_DB_PORT=5432.

# --- Remote droplet CRM from dev container (no TCP bridge on Windows host) ---
# Uncomment if the dev container can route to the tailnet and Postgres is exposed there.
# CC_DOCKER_CRM_DB_HOST=100.74.54.12
# CC_DOCKER_CRM_DB_PORT=5432

# --- Remote droplet CRM via host forwarder (bridge/tunnel on 5433) ---
# Use scripts/dev-docker-up.ps1 -UseRemoteCrm instead of setting these, or set:
# CC_DOCKER_CRM_DB_HOST=host.docker.internal
# CC_DOCKER_CRM_DB_PORT=5433
