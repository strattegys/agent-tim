# Environment files with secrets
.env
*.env.local
bws.secret-projects.json
.env.bws.local
config.json

# API Keys and sensitive data
**/config.json
**/*_API_KEY*
**/*TOKEN*
**/*SECRET*
# Allow the Bitwarden setup doc and example project map (names contain "secret")
!docs/BITWARDEN-SECRETS.md
!bws.secret-projects.json.example

# Logs
*.log
logs/

# OS files
.DS_Store
Thumbs.db

# Local agent IDE folders (do not commit)
.claude/

# Editor files
.vscode/
.idea/
*.swp
*.swo
*~

# Backup files
*.backup
*.backup2
*.bak
*.tar.gz

# Temporary files
tmp/
temp/

# Node
node_modules/
.next/

# Python
*.pyc
__pycache__/
.venv/

# NanoClaw legacy (deprecated)
nanoclaw/
**/nanoclaw/**

# Docker bind-mount: uploaded agent photos (keep folder in git via .gitkeep)
docker-data/agent-avatars/*
!docker-data/agent-avatars/.gitkeep

# Local CRM pg_dump snapshots (populate dev — never commit)
docker-data/*.dump

# Local dev: session JSONL / memory under agents/ (do not commit; prod uses host bind mount)
agents/.*/
