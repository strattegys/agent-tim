# Copy to .env.development.local (gitignored). Loaded only by `next dev` — overrides web/.env.local.
# LOCALDEV runs on port 3010 (`npm run dev`). Match Auth.js to that origin:
NEXTAUTH_URL=http://localhost:3010
AUTH_URL=http://localhost:3010

# Optional; npm script also sets this for `next dev`
# NEXT_PUBLIC_CC_RUNTIME_LABEL=LOCALDEV

# Example: point native Node dev at a different tunnel port without editing .env.local
# CRM_DB_HOST=127.0.0.1
# CRM_DB_PORT=5434

# Example: ephemeral Suzi only while hacking UI
# CHAT_EPHEMERAL_AGENTS=suzi

# Example: dev-only model (compose already sets GROQ_CHAT_MODEL in Docker dev)
# GROQ_CHAT_MODEL=llama-3.3-70b-versatile

# Example: flip UI mode without touching production-parity .env.local
# CC_PUBLIC_APP_UI=true
