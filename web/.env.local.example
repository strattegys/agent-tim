# Google OAuth (get from https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
NEXTAUTH_SECRET=generate_with_openssl_rand_base64_32
NEXTAUTH_URL=http://localhost:3001
# Auth.js v5 also reads AUTH_SECRET and AUTH_URL (same values as above).
# LOCALPROD (`npm run local-prod`) uses port 3001 — keep these on localhost:3001 for that mode.
# LOCALDEV (`npm run dev` or docker-compose.dev.yml) uses port 3010 — override in .env.development.local or rely on compose.
# Use the same host in the browser as NEXTAUTH_URL (do not mix localhost and 127.0.0.1).
# Production behind Caddy: set NEXTAUTH_URL or AUTH_URL to the public https origin (e.g. https://command.example.com)
# so cookies and host checks work. docker-compose uses env_file: web/.env.local — include these there.
# Production Docker: root `docker-compose.yml` passes AUTH_SECRET / NEXTAUTH_SECRET as **build args** from this file
# (`docker compose --env-file web/.env.local build web`) so Edge middleware can sign sessions — keep the same values at runtime.

# Server crons (LinkedIn inbox drain, catch-up, warm-outreach discovery, agent heartbeats): **hosted DigitalOcean app only**.
# LOCALDEV / LOCALPROD and `next dev` never run timers. Friday → Cron proxies live last-run data from production.
# Default host is https://stratt-central.b2bcontentartist.com if CC_HOSTED_APP_URL is unset (override for staging).
# INTERNAL_API_KEY must match the droplet web/.env.local (see scripts/patch-server-internal-api-key.mjs), or use CC_HOSTED_INTERNAL_API_KEY.
# Hosted-only kill switch — CC_DISABLE_SERVER_CRON=1

# Optional — droplet only: hide the main app UI (/, /chat, kanban, etc.). APIs and webhooks stay live.
# Values (case-insensitive): false | 0 | backend | off  →  visitors see /backend-only; use local Docker dev for the full UI.
# Omit or set true for a normal public UI on production.
# CC_PUBLIC_APP_UI=backend

# Whitelisted email - only this account can log in
ALLOWED_EMAIL=your@email.com

# Groq — agent chat (agent-registry), TTS voice summarization, agent card summaries, CRM artifact chat, etc.
GROQ_API_KEY=your_groq_api_key
# Tim only: first SSE chunk includes merged work-queue + UI context (LinkedIn thread check). Shows in chat as “Context debug”.
# Do not enable on shared/production hosts — contains CRM/thread text. Values: 1 | true | yes
# TIM_CHAT_CONTEXT_DEBUG=1
# Log each Groq chat/completions request/response to the **web container stdout** (not the browser). Values: 1 | true | yes
# Docker dev: `docker compose -f docker-compose.dev.yml logs -f web` or Docker Desktop → web container → Logs — search `[groq-debug]`.
# GROQ_CHAT_DEBUG=1
# Friday → Observation Post (runtime toggles for GROQ_CHAT_DEBUG / TIM_CHAT_CONTEXT_DEBUG):
# - next dev: always on (NODE_ENV=development).
# - Docker production build: set OBSERVATION_POST_API=1 (docker-compose.local-prod-desktop.yml sets this for LOCALPROD).
# - Optional alias: DEV_UNIPILE_INBOUND_REPLAY=1 (same gate as replay-unipile-inbound).
# Same gate: buffered Groq debug lines and /api middleware hits (see /api/dev/observability/logs and edge-logs).
# OBSERVATION_POST_API=1
# Tim lab: buffer Unipile webhook payloads for GET /api/dev/observability/logs?category=unipile (NODE_ENV=development buffers by default).
# Set on production-style builds (e.g. next start) when you need the dock without dev. Values: 1 | true | yes
# TIM_LAB_UNIPILE_LOG=1
# Optional: override model for every Groq-backed agent (default: openai/gpt-oss-120b in agent-registry + fallbacks).
# docker-compose.dev.yml sets GROQ_CHAT_MODEL=openai/gpt-oss-120b explicitly (same as default).
# GROQ_CHAT_MODEL=openai/gpt-oss-120b

# Gemini — vector embeddings (768-dim, pgvector): Suzi memory, Marni Knowledge Studio research runs, Tim PDF uploads (Knowledge panel), optional chat fallback if an agent omits provider: "groq"
# Create a key: https://aistudio.google.com/apikey
# File must be web/.env.local (next to package.json). After changes, restart next dev or Docker web container.
# Also accepted: GOOGLE_GENERATIVE_AI_API_KEY, GOOGLE_API_KEY (see lib/gemini-api-key.ts).
GEMINI_API_KEY=your_gemini_api_key

# Anthropic API — optional unless you use article_builder / agents with provider "anthropic"
ANTHROPIC_API_KEY=your_anthropic_api_key
# article_builder: tries structured JSON (output_config) on primary + fallback, then legacy Opus without schema.
# Defaults: claude-opus-4-6 → claude-opus-4-5-20251101 → claude-opus-4-20250514
# ANTHROPIC_ARTICLE_MODEL=claude-opus-4-6
# ANTHROPIC_ARTICLE_STRUCTURED_FALLBACK_MODEL=claude-opus-4-5-20251101
# ANTHROPIC_ARTICLE_LEGACY_FALLBACK_MODEL=claude-opus-4-20250514

# Inworld TTS — required for read-aloud (same as Rainbow Bot: rainbow/avabot_server.py)
# Use the SAME INWORLD_TTS_KEY value as on the Project Server Rainbow container.
# Agent registry: Suzi → Olivia, Tim → Timothy, Ghost → Avery (see web/lib/agent-registry.ts ttsVoice).
INWORLD_TTS_KEY=
# Optional global fallback for /api/tts when registry has no ttsVoice; Suzi uses registry Olivia — set this to the same on the droplet for parity.
INWORLD_VOICE_ID=Olivia

# Suzi local testing — chat + memory under web/.dev-ephemeral-chat/suzi/ (gitignored), no vector RAG, no session consolidation
# CHAT_EPHEMERAL_AGENTS=suzi

# Session files, memory dirs, and system prompts use paths like /root/.suzibot/... in the registry.
# Set AGENT_ROOT to the folder that contains .suzibot, .nanobot, .fridaybot, etc. (same layout as /root on the bot host).
# Production Docker: web/Dockerfile sets AGENT_ROOT=/agents and copies repo agents/ → /agents (see docker-compose.yml).
# Local Node dev: point at your checkout, e.g. AGENT_ROOT=C:\path\to\COMMAND-CENTRAL\agents
# AGENT_ROOT=
#
# Chat JSONL + file memory: docker-compose.dev.yml and npm run dev set CC_AGENT_CHAT_PROFILE=localdev (under sessions/localdev/).
# LOCALPROD (Docker overlay + npm run start:local-prod) omits this — same paths as droplet (sessions/web_*.jsonl next to agent dirs).
# Do not set CC_AGENT_CHAT_PROFILE=localprod (obsolete); the app treats localprod like canonical paths. On Windows, never export
# CC_AGENT_CHAT_PROFILE in the shell when using Docker LOCALPROD — Compose can inherit it and hide chat history.
# Droplet production: omit. Override only for a custom sandbox: [a-zA-Z0-9._-]+
# CC_AGENT_CHAT_PROFILE=localdev

# Suzi Intake — inbound email (Postmark/Mailgun/etc. POSTs JSON or form fields to this app; no mail server). Webhook path: /api/webhooks/intake-inbound
# Verify with ?secret=…, path /api/webhooks/intake-inbound/<secret> (recommended for Postmark), header x-intake-inbound-secret, or Authorization: Bearer …
# INTAKE_INBOUND_WEBHOOK_SECRET=
# Comma-separated allowed From addresses (parsed email must match exactly, case-insensitive).
# INTAKE_INBOUND_ALLOWED_FROM=you@yourdomain.com

# Internal middleware bypass — required for Unipile webhook → warm-outreach auto “Replied” (server calls /api/crm/human-tasks/resolve without a browser session). Production droplet: set this in web/.env.local (see scripts/patch-server-internal-api-key.mjs).
# Same key (or CC_HOSTED_INTERNAL_API_KEY) + CC_HOSTED_APP_URL lets local / LOCALPROD load Friday → Cron from the hosted app.
INTERNAL_API_KEY=
# CC_HOSTED_APP_URL=https://your-command-central.example.com
# Optional: override loopback self-fetch (defaults to http://127.0.0.1:$PORT). Multi-node / unusual routing only.
# Also used by warm-outreach cron to POST /api/crm/human-tasks/resolve when MESSAGED follow-up is due.
# APP_INTERNAL_URL=http://127.0.0.1:3001

# Suzi CRM reminders (heartbeat): emergency stop = 1. Optional: SUZI_REMINDER_BELL_THROTTLE_MS=0 turns off cross-process bell cooldown file.
# DISABLE_SUZI_REMINDER_HEARTBEAT=1
# SUZI_REMINDER_BELL_COOLDOWN_FILE=/path/to/suzi_reminder_bell_last

# Optional: Twenty GraphQL tools / heartbeat (leave unset if unused)
TWENTY_CRM_API_KEY=your_twenty_crm_api_key
TWENTY_CRM_URL=http://localhost:3000

# CRM PostgreSQL — Kanban, workflow builder, human-tasks, packages (Command Central’s own data)
# Status rail "Data Platform" probes this when CRM_DB_PASSWORD is set (not TWENTY_CRM_URL).
# Without CRM_DB_PASSWORD the app uses .dev-store/ (empty fake data) — boards will not show real pipelines.
#
# ── Production Docker (droplet) ──
# Bitwarden `command-central-production`: CRM_DB_HOST=crm-db, CRM_DB_PORT=5432, plus password (and name/user if non-default).
# docker-compose.yml sets CC_RUNTIME_STACK=HOSTED and CC_BUNDLED_CRM_SERVICE=1 (compose only — do not put the latter in Bitwarden).
# docker-compose.yml runs service `crm-db` on the same compose network as `web` and sets crm-db:5432 on `web`; hosted Docker also
# ignores laptop-style tunnel host/port if they appear in a pulled file.
# You still MUST set CRM_DB_PASSWORD (and CRM_DB_NAME / CRM_DB_USER if not default) here — compose
# passes the same values to Postgres on first boot. Always deploy with:
#   docker compose --env-file web/.env.local -f docker-compose.yml up -d
# One-time copy from an old Postgres container (e.g. twenty-db-1): scripts/migrate-crm-postgres-from-legacy-container.sh
CRM_DB_HOST=host.docker.internal
# Production (docker-compose.yml web→crm-db): use 5432. Docker dev compose overrides to 5433 — see below.
CRM_DB_PORT=5432
CRM_DB_NAME=default
CRM_DB_USER=postgres
CRM_DB_PASSWORD=your_postgres_password
#
# ── Local dev: Docker (docker-compose.dev.yml) — bundled dev Postgres (default) ──
# **Tim on LOCALDEV UI (localhost:3010) but production CRM:** `.\scripts\dev-docker-up.ps1 -UseRemoteCrm`
# (tunnel/bridge + docker-compose.dev-remote-crm.yml). Values below for CRM_DB_HOST/PORT are overridden by
# compose for the **web** container unless you use that overlay; `-UseRemoteCrm` is what switches web → droplet DB.
# `.\scripts\dev-docker-up.ps1` (no flag) starts **cc-localdev-crm-db** + Next; **web** uses CRM_DB_HOST=crm-db.
#
# From Windows (pg_restore, npm run db:exec): CRM_DB_HOST=127.0.0.1  CRM_DB_PORT=25432  (same password as here).
# If you leave CRM_DB_HOST=crm-db (Compose service name), host-side Node auto-remaps to 127.0.0.1:25432 (see lib/db.ts + scripts/crm-db-pool.mjs).
# CRM_DB_LOCAL_PORT=25432
# Optional: `docker compose --env-file web/.env.local -f docker-compose.dev.yml exec crm-db psql -U postgres -d default`
#
# Fresh volume = empty schema until you pg_restore a dump or run migrations. Vector init: web/scripts/migrate-vector-memory.sql
#
# ── LOCALPROD Docker (docker-compose.local-prod-desktop.yml) — same DB as production droplet ──
# Default: Tailscale CRM (100.74.54.12:5432). Tunnel fallback: run .\scripts\localprod-crm-tunnel.ps1 then set
# CC_LOCALPROD_CRM_HOST=host.docker.internal and CC_LOCALPROD_CRM_PORT=5433 in **COMMAND-CENTRAL/.env** or your shell
# (not here) — because `docker compose --env-file web/.env.local` uses this file for variable substitution and
# CRM_LOCALPROD_DB_HOST=127.0.0.1 (copied from host-only db:exec hints) lands **inside the container** and breaks crons.
# Keep CRM_DB_PASSWORD (and name/user) aligned with the droplet. Host db:exec with tunnel: CRM_DB_HOST=127.0.0.1 CRM_DB_PORT=5433
# CRM_LOCALPROD_DB_PORT=5433
# CRM_LOCALPROD_DB_HOST=host.docker.internal
#
# ── Local dev: Docker + live droplet CRM (optional) ──
#   .\scripts\dev-docker-up.ps1 -UseRemoteCrm   (Tailscale bridge or SSH tunnel to 0.0.0.0:5433, then host.docker.internal)
#   Flags: -UseSshTunnel  -UseTailscaleBridge   |  Reconnect: cd web && npm run db:reconnect
# Direct from dev container (advanced): CC_DOCKER_CRM_DB_HOST=100.x  CC_DOCKER_CRM_DB_PORT=5432 when running compose

# Tailscale: Native Node dev (no Docker): CRM_DB_HOST=<droplet 100.x>  CRM_DB_PORT=5432 — no bridge or SSH.
#
# Tunnel binds 0.0.0.0:5433 by default when using -UseRemoteCrm.
# Agent vector RAG: pgvector/pgvector:pg16 + migrate-vector-memory.sql. check-crm-db verifies extension + _memory.
# Marni Knowledge Studio: web/scripts/migrate-marni-kb.sql — same psql pattern as migrate-intake.sql.
# Inside the **web** Docker container, do not point CRM_DB at 127.0.0.1 — use compose defaults (crm-db) or tunnel (host.docker.internal).
#
# ── Local dev: Node on the host only (npm run dev, no Docker) ──
# Then CRM_DB_HOST=127.0.0.1 and CRM_DB_PORT=5433 (or 5432) is correct with the same tunnel.
#
# Optional: single URL instead of CRM_DB_* (db-exec.mjs and some tools)
# DATABASE_URL=postgresql://postgres:PASSWORD@127.0.0.1:5432/default
#
# Optional: override workspace schema for db-exec.mjs (default matches lib/db.ts)
# CRM_DB_SEARCH_PATH=workspace_9rc10n79wgdr0r3z6mzti24f6
#
# Run SQL from repo root (loads .env.local automatically):
#   cd web && npm run db:exec -- scripts/seed-vibe-coding-warm-outreach-package.sql
#   cd web && npm run db:exec -- -e "SELECT id, name FROM \"_package\" LIMIT 3"

# LinkedIn (ConnectSafely) - optional
CONNECTSAFELY_API_KEY=your_connectsafely_api_key
CONNECTSAFELY_ACCOUNT_ID=your_account_id

# LinkedIn via Unipile — warm-outreach RESEARCHING enrichment + /api/webhooks/unipile
# DSN is host:port from the Unipile dashboard (e.g. api32.unipile.com:16299). No https:// prefix.
# Local dev (Govind): same production UNIPILE_* from Bitwarden / bws-pull on this machine is OK — dev scripts and replay hit the live LinkedIn account; use replay dryRun when unsure.
UNIPILE_API_KEY=
UNIPILE_DSN=api32.unipile.com:16299
UNIPILE_ACCOUNT_ID=
# Optional: Unipile dashboard → webhook auth header unipile-auth. Also allows POST /api/crm/human-tasks/resolve with Authorization: Bearer <this> if INTERNAL_API_KEY is unset (see middleware.ts).
UNIPILE_WEBHOOK_SECRET=
# Master pause: no Unipile webhook queue/process, no webhook inbox drain / LinkedIn catch-up / connection-poll crons. Remove and restart web to resume.
# LINKEDIN_AUTOMATION_DISABLED=1
# Optional: Govind’s LinkedIn member id (ACoA…) — outbound detection in webhook + replay. Defaults match production placeholder in code if unset.
# LINKEDIN_SELF_PROVIDER_ID=

# Dev: allow POST /api/dev/replay-unipile-inbound when NODE_ENV is production (e.g. Docker). Native `next dev` does not need this.
# DEV_UNIPILE_INBOUND_REPLAY=1
# Unipile replay (CLI + /api/dev/replay-unipile-inbound) refuses CRM writes unless CRM_DB_HOST is loopback or crm-db (bundled Docker Postgres).
# Set only for a deliberate non-prod DB session (e.g. staging). Never on the production droplet.
# UNIPILE_REPLAY_ALLOW_REMOTE_CRM=1
# Local bundled CRM: see COMMAND-CENTRAL/docs/LOCAL-CRM-DATABASE.md (host tools: CRM_DB_HOST=127.0.0.1 CRM_DB_PORT=25432).

# Project Server — optional probe for Rainbow (system monitor groups with Strattegys under “Website-Projects”). Example host from PROJECT-SERVER Caddy:
# PROJECT_SERVER_RAINBOW_URL=https://rainbow.b2bcontentartist.com

# Brave Search — required for Marni Knowledge Studio “web” research runs (not optional if you use Run now with web queries).
# https://brave.com/search/api/
BRAVE_SEARCH_API_KEY=your_brave_search_api_key

# Path to tool scripts
TOOL_SCRIPTS_PATH=/root/.nanobot/tools

# Agent avatar uploads (POST /api/agent-avatar → GET /api/agent-avatar?id=…)
# Production & Docker dev: compose sets AVATAR_DIR=/data/agent-avatars and mounts ./docker-data/agent-avatars (persistent on the host).
# Native `npm run dev` from web/ without Docker: defaults to COMMAND-CENTRAL/docker-data/agent-avatars (sibling of web/).
# Override if needed, e.g. Windows absolute path:
# AVATAR_DIR=C:\path\to\COMMAND-CENTRAL\docker-data\agent-avatars
