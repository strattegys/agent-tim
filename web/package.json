{
  "name": "command-central",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "cross-env NEXT_PUBLIC_CC_RUNTIME_LABEL=LOCALDEV CC_AGENT_CHAT_PROFILE=localdev next dev -p 3010",
    "dev:friday": "cross-env NEXT_PUBLIC_CC_RUNTIME_LABEL=LOCALDEV NEXT_PUBLIC_CC_FRIDAY_DEV=1 CC_AGENT_CHAT_PROFILE=localdev next dev -p 3011",
    "build": "next build && node scripts/copy-standalone-assets.mjs",
    "build:local-prod": "cross-env NEXT_PUBLIC_CC_RUNTIME_LABEL=LOCALPROD next build && node scripts/copy-standalone-assets.mjs",
    "start": "next start",
    "start:local-prod": "cross-env NEXT_PUBLIC_CC_RUNTIME_LABEL=LOCALPROD next start -p 3001",
    "local-prod": "npm run build:local-prod && npm run start:local-prod",
    "check-tts": "node scripts/check-inworld-tts.mjs",
    "sync:inworld": "node scripts/sync-inworld-from-rainbow.mjs",
    "push:inworld:prod": "node scripts/push-inworld-production.mjs",
    "db:exec": "node scripts/db-exec.mjs",
    "seed:tim-test-queue": "npx tsx scripts/seed-tim-test-queue.ts",
    "check-crm-db": "node scripts/check-crm-db.mjs",
    "check-gemini-env": "node scripts/check-gemini-env.mjs",
    "db:reconnect": "powershell -NoProfile -ExecutionPolicy Bypass -File ../scripts/dev-db-reconnect.ps1",
    "db:reconnect:bridge": "powershell -NoProfile -ExecutionPolicy Bypass -File ../scripts/dev-db-reconnect.ps1 -UseTailscaleBridge",
    "db:bridge": "node ../scripts/crm-db-tailscale-bridge.mjs",
    "check-crm-db:no-ts-fallback": "node scripts/check-crm-db.mjs --no-tailscale-fallback",
    "db:vector-memory": "node scripts/db-exec.mjs scripts/migrate-vector-memory.sql",
    "db:linkedin-inbound-receipt": "node scripts/db-exec.mjs scripts/migrate-linkedin-inbound-receipt.sql",
    "check:linkedin-inbound-receipt": "npx tsx scripts/check-linkedin-inbound-receipt.ts",
    "db:punch-list-actions": "node scripts/db-exec.mjs scripts/migrate-punch-list-actions-jsonb.sql",
    "migrate:orphan-workflows": "node scripts/migrate-orphan-workflows-to-packages.mjs",
    "prune:linkedin-connection-alerts": "node scripts/prune-linkedin-connection-notifications.mjs",
    "dev:unipile-recent": "node scripts/unipile-recent-chats.mjs",
    "dev:unipile-replay-queue": "node -r ./scripts/empty-server-only.cjs --import tsx ./scripts/run-unipile-inbound-replay.ts",
    "dev:unipile-seed-tim-queue": "node -r ./scripts/empty-server-only.cjs --import tsx ./scripts/run-unipile-inbound-replay.ts -- --max-inbound 10 --max-chats 30",
    "dev:unipile-export-inbound-sample": "node -r ./scripts/empty-server-only.cjs --import tsx ./scripts/run-unipile-inbound-replay.ts -- --export-sample tmp/unipile-inbound-last10.json --max-inbound 10 --max-chats 30",
    "dev:unipile-sync-recent-dry": "node -r ./scripts/empty-server-only.cjs --import tsx ./scripts/run-unipile-inbound-replay.ts -- --dry-run --days 4 --max-chats 500 --max-inbound 200 --messages-per-chat 50 --relations",
    "dev:unipile-sync-recent": "node -r ./scripts/empty-server-only.cjs --import tsx ./scripts/run-unipile-inbound-replay.ts -- --days 4 --max-chats 500 --max-inbound 200 --messages-per-chat 50 --relations",
    "backfill:jebin": "node -r ./scripts/empty-server-only.cjs --import tsx ./scripts/backfill-warm-replied-inbound.ts",
    "backfill:warm-replied-inbound": "node -r ./scripts/empty-server-only.cjs --import tsx ./scripts/backfill-warm-replied-inbound.ts",
    "migrate:tim-crm-slice": "node scripts/migrate-tim-crm-slice.mjs",
    "migrate:linkedin-connection-intake": "node -r ./scripts/empty-server-only.cjs --import tsx ./scripts/migrate-linkedin-connection-intake-items.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@google/genai": "^1.45.0",
    "next": "16.1.6",
    "next-auth": "^5.0.0-beta.30",
    "node-cron": "^4.2.1",
    "pdf-parse": "^1.1.1",
    "pg": "^8.20.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/node-cron": "^3.0.11",
    "@types/pdf-parse": "^1.1.5",
    "@types/pg": "^8.18.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cross-env": "^7.0.3",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
